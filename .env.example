# ============================================
# Zaccess - Variáveis do servidor (raiz do projeto)
# Copie para .env e preencha os valores.
# ============================================

NODE_ENV=development
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# MongoDB (o server lê MONGO_URI; Docker usa as MONGO_INITDB_*)
MONGO_URI=mongodb://localhost:27017/zacess
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=sua_senha_mongo
MONGO_INITDB_DATABASE=zacess

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_redis

# JWT
JWT_SECRET=altere_para_uma_chave_secreta_forte
JWT_EXPIRES_IN=7d

# Docs (OpenAPI/Swagger) - acesso via Basic Auth
DOCS_USERNAME=admin
DOCS_PASSWORD=troque_esta_senha
# Origem principal do painel/API pública; inclua outros domínios separados por vírgula se precisar
CORS_ALLOWED_ORIGINS=https://api.zroot.online,https://app.seudominio.com
TRUST_PROXY=1
FORCE_HTTPS=true

# URLs publicas (Cloudflare / HTTPS) — canônico: api.zroot.online
PUBLIC_BASE_URL=https://api.zroot.online
VITE_API_URL=https://api.zroot.online
VITE_WS_URL=https://api.zroot.online
EXPO_PUBLIC_API_URL=https://api.zroot.online
CLOUDFLARE_TUNNEL_TOKEN=

# Observabilidade (Docker)
OBSERVABILITY_BIND_ADDR=127.0.0.1
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=troque_esta_senha
ALERT_WEBHOOK_URL=http://localhost:9999/alerts
ALERT_WEBHOOK_TIMEOUT=5s
ALERT_WEBHOOK_SEND_RESOLVED=true
ALERT_GROUP_WAIT=15s
ALERT_GROUP_INTERVAL=1m
ALERT_REPEAT_INTERVAL=2h
LOG_RETENTION_DAYS=15
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=8GB
SLO_AVAILABILITY_TARGET=99.9
SLO_ERROR_BUDGET=0.1
APDEX_TARGET=0.94
APDEX_TOLERATED=0.85
