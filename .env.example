# ============================================
# Zaccess - Variáveis do servidor (raiz do projeto)
# Copie para .env e preencha os valores.
# ============================================

NODE_ENV=development
SERVER_PORT=3001
SERVER_HOST=0.0.0.0

# MongoDB (o server lê MONGO_URI; Docker usa as MONGO_INITDB_*)
MONGO_URI=mongodb://localhost:27017/zacess
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=sua_senha_mongo
MONGO_INITDB_DATABASE=zacess

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_redis

# JWT
JWT_SECRET=altere_para_uma_chave_secreta_forte
JWT_EXPIRES_IN=7d

# URLs para o frontend (client) - usar em desenvolvimento
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
