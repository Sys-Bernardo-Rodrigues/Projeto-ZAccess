{
  "id": null,
  "uid": "zaccess-noc",
  "title": "ZAccess - NOC (SLA/SLO)",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 10,
  "refresh": "10s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "stat",
      "title": "API Status",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "max(up{job=\"zaccess_server\"} or vector(0))", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFFLINE" }, "1": { "text": "ONLINE" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] },
          "color": { "mode": "thresholds" },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "SLO Violado (alerta)",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(sum(ALERTS{alertname=~\"ZaccessErrorBudgetBurnRateFast|ZaccessErrorBudgetBurnRateSlow\",alertstate=\"firing\"}) or vector(0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "range", "options": { "from": 0, "to": 0.99, "result": { "text": "OFF" } } },
            { "type": "range", "options": { "from": 1, "to": 1000, "result": { "text": "ON" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Disponibilidade API (24h %)",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "((100 * max(sum_over_time(up{job=\"zaccess_server\"}[24h])) / clamp_min(max(count_over_time(up{job=\"zaccess_server\"}[24h])), 1)) or vector(0))", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 99, "color": "yellow" }, { "value": 99.9, "color": "green" }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "type": "stat",
      "title": "Error Budget Consumido (24h %)",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "((clamp_max((((1 - (max(sum_over_time(up{job=\"zaccess_server\"}[24h])) / clamp_min(max(count_over_time(up{job=\"zaccess_server\"}[24h])), 1))) / 0.001) * 100), 1000) and on() (max(count_over_time(up{job=\"zaccess_server\"}[24h])) >= 1000)) or vector(0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 50, "color": "yellow" }, { "value": 100, "color": "red" }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "type": "stat",
      "title": "RPS Atual",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(sum(rate(http_requests_total{job=\"zaccess_server\"}[1m])) or vector(0))", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] } }, "overrides": [] },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "type": "stat",
      "title": "Erro 5xx (5m %)",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(((sum(rate(http_requests_total{job=\"zaccess_server\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"zaccess_server\"}[5m])), 1)) * 100) or vector(0))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 5, "color": "red" }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" } }
    },
    {
      "type": "timeseries",
      "title": "RPS e Erro 5xx (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(sum(rate(http_requests_total{job=\"zaccess_server\"}[1m])) or vector(0))", "legendFormat": "RPS", "refId": "A" },
        { "expr": "(sum(rate(http_requests_total{job=\"zaccess_server\",status=~\"5..\"}[5m])) or vector(0))", "legendFormat": "5xx RPS", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latencia p95 e p99 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "((histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"zaccess_server\"}[5m])) by (le)) and on() (sum(rate(http_request_duration_seconds_count{job=\"zaccess_server\"}[5m])) > 0)) or vector(0))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "((histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"zaccess_server\"}[5m])) by (le)) and on() (sum(rate(http_request_duration_seconds_count{job=\"zaccess_server\"}[5m])) > 0)) or vector(0))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disponibilidade por Servico (24h %)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "((max(avg_over_time(up{job=\"zaccess_server\"}[24h])) * 100) or vector(0))", "legendFormat": "API", "refId": "A" },
        { "expr": "((max(avg_over_time(up{job=\"redis_exporter\"}[24h])) * 100) or vector(0))", "legendFormat": "Redis", "refId": "B" },
        { "expr": "((max(avg_over_time(up{job=\"mongodb_exporter\"}[24h])) * 100) or vector(0))", "legendFormat": "MongoDB", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 99, "color": "yellow" }, { "value": 99.9, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Burn Rate (1h / 6h)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(((sum(rate(http_requests_total{job=\"zaccess_server\",status=~\"5..\"}[1h])) / clamp_min(sum(rate(http_requests_total{job=\"zaccess_server\"}[1h])), 1e-9)) / 0.001) or vector(0))",
          "legendFormat": "Burn 1h",
          "refId": "A"
        },
        {
          "expr": "(((sum(rate(http_requests_total{job=\"zaccess_server\",status=~\"5..\"}[6h])) / clamp_min(sum(rate(http_requests_total{job=\"zaccess_server\"}[6h])), 1e-9)) / 0.001) or vector(0))",
          "legendFormat": "Burn 6h",
          "refId": "B"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "tags": ["zaccess", "noc", "slo", "sla", "observability", "production"]
}
