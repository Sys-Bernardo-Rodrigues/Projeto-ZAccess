# URL do servidor Zaccess (remoto). OBRIGATÓRIO incluir a porta (ex: 3001)
# Ex: http://IP:3001  ou  https://seu-servidor.com:3001
ZACESS_SERVER_URL=http://seu-servidor:3001

# Serial do dispositivo (deve estar registrado no servidor)
ZACESS_SERIAL=RPi4-001

# Token de autenticação do dispositivo (gerado no servidor)
ZACESS_AUTH_TOKEN=
